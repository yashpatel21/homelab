#!/bin/bash

LOG_FILE="{{ data_directory }}/scripts/update-check.log"
NTFY_URL="http://localhost:8082"
TOPIC="system-updates"
NTFY_TOKEN="{{ vault_ntfy_token | default('PLACEHOLDER_TOKEN') }}"

# Function to log messages
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S'): $1" >> "$LOG_FILE"
}

log_msg "Starting update check"

# Update package lists
sudo apt update > /dev/null 2>&1

# Only lines that are real upgradable entries contain "[upgradable" (works for any locale;
# the old "Listing..." header and WARNING noise never match).
UPGRADABLE_LIST=$(mktemp) || exit 1
trap 'rm -f "$UPGRADABLE_LIST"' EXIT
apt list --upgradable 2>/dev/null | grep -v "WARNING" | grep -F '[upgradable' >"$UPGRADABLE_LIST"

UPDATES=$(grep -c . "$UPGRADABLE_LIST")
SECURITY_UPDATES=$(grep -ci security "$UPGRADABLE_LIST")

log_msg "Found $UPDATES updates ($SECURITY_UPDATES security)"

if [ "${UPDATES:-0}" -gt 0 ]; then
    # Get list of packages (first 10) from the same snapshot as UPDATES
    PACKAGE_LIST=$(head -10 "$UPGRADABLE_LIST" | cut -d'/' -f1 | tr '\n' ', ' | sed 's/,$//')
    
    if [ "${UPDATES:-0}" -gt 10 ]; then
        PACKAGE_LIST="$PACKAGE_LIST and $((UPDATES-10)) more..."
    fi
    
    # Create properly formatted message with actual line breaks
    MESSAGE="Total packages: $UPDATES
Security updates: $SECURITY_UPDATES

Packages: $PACKAGE_LIST

Run 'sudo apt upgrade' to update.

Check time: $(date '+%Y-%m-%d %H:%M')"
    
    # Send notification with authentication
    if curl -s -H "Authorization: Bearer $NTFY_TOKEN" \
         -H "Title: 📦 Ubuntu Updates Available" \
         -d "$MESSAGE" \
         "$NTFY_URL/$TOPIC" 2>>"$LOG_FILE"; then
        log_msg "Notification sent successfully"
    else
        log_msg "Failed to send notification"
    fi
else
    log_msg "No updates available"
fi

log_msg "Update check completed" 