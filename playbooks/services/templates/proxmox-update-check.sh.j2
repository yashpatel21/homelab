#!/bin/bash

LOG_FILE="/var/log/proxmox-update-check.log"
NTFY_URL="http://{{ ubuntu_server_ip }}:8082"
TOPIC="proxmox-alerts"
NTFY_TOKEN="{{ vault_ntfy_token | default('PLACEHOLDER_TOKEN') }}"
REQUIRE_DOW="{{ update_check_day_of_week.proxmox }}"

# Function to log messages
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S'): $1" >> "$LOG_FILE"
}

# Optional weekday gate (0=Sunday ... 6=Saturday; same as date +%w).
if [ -n "${REQUIRE_DOW}" ]; then
    case "${REQUIRE_DOW}" in
        [0-6]) ;;
        *)
            log_msg "ERROR: update_check_day_of_week.proxmox must be 0-6, got: ${REQUIRE_DOW}"
            exit 1
            ;;
    esac

    TODAY_DOW="$(date +%w)"
    if [ "${TODAY_DOW}" != "${REQUIRE_DOW}" ]; then
        log_msg "Skipping Proxmox update check: weekday ${TODAY_DOW} != required ${REQUIRE_DOW}"
        exit 0
    fi
fi

log_msg "Starting Proxmox update check"

# Update package lists
apt update > /dev/null 2>&1

# Only lines that are real upgradable entries contain "[upgradable" (works for any locale;
# the old "Listing..." header and WARNING noise never match).
UPGRADABLE_LIST=$(mktemp) || exit 1
trap 'rm -f "$UPGRADABLE_LIST"' EXIT
apt list --upgradable 2>/dev/null | grep -v "WARNING" | grep -F '[upgradable' >"$UPGRADABLE_LIST"

UPDATES=$(grep -c . "$UPGRADABLE_LIST")
SECURITY_UPDATES=$(grep -ci security "$UPGRADABLE_LIST")
PVE_UPDATES=$(grep -cE '(pve-|proxmox)' "$UPGRADABLE_LIST")

log_msg "Found $UPDATES total updates ($SECURITY_UPDATES security, $PVE_UPDATES Proxmox-related)"

if [ "${UPDATES:-0}" -gt 0 ]; then
    # Get list of packages (first 10) from the same snapshot as UPDATES
    PACKAGE_LIST=$(head -10 "$UPGRADABLE_LIST" | cut -d'/' -f1 | tr '\n' ', ' | sed 's/,$//')
    
    if [ "${UPDATES:-0}" -gt 10 ]; then
        PACKAGE_LIST="$PACKAGE_LIST and $((UPDATES-10)) more..."
    fi
    
    # Create properly formatted message with specific login instructions
    MESSAGE="Total packages: $UPDATES
Security updates: $SECURITY_UPDATES
Proxmox-related: $PVE_UPDATES

Packages: $PACKAGE_LIST

To update:
- Web UI: Login as root@pam → Node → Updates → Upgrade
- Command line: ssh admin@{{ proxmox_ip }} then 'su -' then 'apt upgrade'

Check time: $(date '+%Y-%m-%d %H:%M')"
    
    # Send notification
    if curl -s -H "Authorization: Bearer $NTFY_TOKEN" \
         -H "Title: 📦 Proxmox Updates Available" \
         -d "$MESSAGE" \
         "$NTFY_URL/$TOPIC" 2>>"$LOG_FILE"; then
        log_msg "Update notification sent successfully"
    else
        log_msg "Failed to send notification"
    fi
else
    log_msg "No updates available"
fi

log_msg "Proxmox update check completed" 